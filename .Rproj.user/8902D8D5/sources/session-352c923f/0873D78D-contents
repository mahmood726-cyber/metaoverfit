#' metaoverfit: Optimism-Corrected Heterogeneity in Meta-Regression
#'
#' @description
#' This package provides tools for detecting and correcting overfitting in
#' meta-regression analyses through cross-validation and bootstrap methods.
#'
#' @docType package
#' @name metaoverfit
NULL

#' Calculate Apparent R-squared for Heterogeneity
#'
#' @param yi Vector of effect sizes
#' @param vi Vector of sampling variances
#' @param mods Model matrix or formula for moderators
#' @param data Optional data frame
#' @param method Heterogeneity estimator (default: "REML")
#'
#' @return List containing R²_het and model components
#' @export
#'
#' @examples
#' # Example with simulated data
#' k <- 30
#' yi <- rnorm(k, 0, sqrt(0.1))
#' vi <- runif(k, 0.01, 0.1)
#' mods <- cbind(1, rnorm(k))
#' r2het(yi, vi, mods)
#'
r2het <- function(yi, vi, mods = NULL, data = NULL, method = "REML") {

  # Input validation
  if(length(yi) != length(vi)) {
    stop("yi and vi must have the same length")
  }

  # Fit null model
  fit_null <- metafor::rma(yi = yi, vi = vi, data = data, method = method)
  tau2_null <- fit_null$tau2
  I2 <- fit_null$I2

  # If no moderators, return 0
  if(is.null(mods)) {
    return(list(
      r2het = 0,
      tau2_null = tau2_null,
      tau2_full = tau2_null,
      I2 = I2,
      k = length(yi),
      p = 1,
      model = fit_null
    ))
  }

  # Handle formula or matrix input
  if(inherits(mods, "formula")) {
    fit_full <- metafor::rma(yi = yi, vi = vi, mods = mods,
                             data = data, method = method)
    p <- length(coef(fit_full))
  } else {
    # Ensure matrix format
    mods <- as.matrix(mods)
    fit_full <- metafor::rma(yi = yi, vi = vi, mods = ~ mods - 1,
                             data = data, method = method)
    p <- ncol(mods)
  }

  tau2_full <- fit_full$tau2

  # Calculate R²_het
  r2het_val <- if(tau2_null > 0) {
    max(0, 1 - tau2_full/tau2_null)
  } else {
    0
  }

  # Calculate adjusted R²_het
  k <- length(yi)
  r2het_adj <- if(tau2_null > 0 & k > p) {
    max(0, 1 - (tau2_full/tau2_null) * ((k-1)/(k-p)))
  } else {
    0
  }

  return(list(
    r2het = r2het_val,
    r2het_adj = r2het_adj,
    tau2_null = tau2_null,
    tau2_full = tau2_full,
    I2 = I2,
    k = k,
    p = p,
    model_null = fit_null,
    model_full = fit_full
  ))
}

#' Cross-Validated R-squared for Heterogeneity
#'
#' @param yi Vector of effect sizes
#' @param vi Vector of sampling variances
#' @param mods Model matrix or formula for moderators
#' @param data Optional data frame
#' @param method Heterogeneity estimator (default: "REML")
#' @param cv_method "loo" for leave-one-out or "kfold" for k-fold CV
#' @param k_folds Number of folds for k-fold CV (default: 5)
#' @param verbose Show progress bar
#'
#' @return List containing apparent, corrected, and optimism values
#' @export
#'
#' @examples
#' k <- 30
#' yi <- rnorm(k, 0, sqrt(0.1))
#' vi <- runif(k, 0.01, 0.1)
#' mods <- cbind(1, rnorm(k))
#' result <- r2het_cv(yi, vi, mods)
#' print(paste("Optimism:", round(result$optimism * 100, 1), "%"))
#'
r2het_cv <- function(yi, vi, mods = NULL, data = NULL, method = "REML",
                     cv_method = "loo", k_folds = 5, verbose = TRUE) {

  k <- length(yi)

  # Get apparent R²_het
  apparent <- r2het(yi, vi, mods, data, method)

  # If no moderators, return 0
  if(is.null(mods)) {
    return(list(
      r2het_apparent = 0,
      r2het_corrected = 0,
      optimism = 0,
      tau2_cv = apparent$tau2_null,
      convergence_rate = 100
    ))
  }

  # Prepare moderator matrix
  if(inherits(mods, "formula")) {
    if(!is.null(data)) {
      mods_matrix <- model.matrix(mods, data)
    } else {
      stop("Data must be provided when using formula for mods")
    }
  } else {
    mods_matrix <- as.matrix(mods)
  }

  p <- ncol(mods_matrix)

  # Check if enough observations
  if(k <= p + 1) {
    warning("Too few studies for stable cross-validation (k <= p+1)")
    return(list(
      r2het_apparent = apparent$r2het,
      r2het_corrected = 0,
      optimism = apparent$r2het,
      convergence_rate = 0
    ))
  }

  # Leave-one-out CV
  if(cv_method == "loo") {
    yhat_cv <- rep(NA, k)
    converged <- rep(FALSE, k)

    if(verbose) pb <- txtProgressBar(min = 0, max = k, style = 3)

    for(i in 1:k) {
      tryCatch({
        # Fit without study i
        fit_cv <- metafor::rma(yi = yi[-i], vi = vi[-i],
                               mods = ~ mods_matrix[-i,, drop = FALSE] - 1,
                               method = method)

        # Predict study i
        yhat_cv[i] <- sum(mods_matrix[i,] * coef(fit_cv))
        converged[i] <- TRUE
      }, error = function(e) {
        yhat_cv[i] <- NA
      })

      if(verbose) setTxtProgressBar(pb, i)
    }

    if(verbose) close(pb)

  } else if(cv_method == "kfold") {
    # K-fold CV
    folds <- sample(rep(1:k_folds, length.out = k))
    yhat_cv <- rep(NA, k)
    converged <- rep(FALSE, k)

    for(fold in 1:k_folds) {
      test_idx <- which(folds == fold)
      train_idx = which(folds != fold)

      tryCatch({
        fit_cv <- metafor::rma(yi = yi[train_idx], vi = vi[train_idx],
                               mods = ~ mods_matrix[train_idx,, drop = FALSE] - 1,
                               method = method)

        for(j in test_idx) {
          yhat_cv[j] <- sum(mods_matrix[j,] * coef(fit_cv))
          converged[j] <- TRUE
        }
      }, error = function(e) {})
    }
  }

  # Calculate cross-validated tau²
  valid <- converged & !is.na(yhat_cv)

  if(sum(valid) > k/2) {
    tau2_cv <- mean(pmax(0, (yi[valid] - yhat_cv[valid])^2 - vi[valid]))

    r2het_cv <- if(apparent$tau2_null > 0) {
      max(0, 1 - tau2_cv/apparent$tau2_null)
    } else {
      0
    }

    # Calculate prediction metrics
    rmse <- sqrt(mean((yi[valid] - yhat_cv[valid])^2))
    mae <- mean(abs(yi[valid] - yhat_cv[valid]))
    correlation <- cor(yi[valid], yhat_cv[valid])
  } else {
    r2het_cv <- NA
    tau2_cv <- NA
    rmse <- NA
    mae <- NA
    correlation <- NA
  }

  # Calculate optimism
  optimism <- if(!is.na(r2het_cv)) {
    apparent$r2het - r2het_cv
  } else {
    NA
  }

  return(list(
    r2het_apparent = apparent$r2het,
    r2het_corrected = r2het_cv,
    optimism = optimism,
    tau2_null = apparent$tau2_null,
    tau2_cv = tau2_cv,
    convergence_rate = sum(valid)/k * 100,
    rmse = rmse,
    mae = mae,
    correlation = correlation,
    predictions = if(sum(valid) > 0) yhat_cv else NULL
  ))
}

#' Bootstrap Confidence Intervals for R-squared
#'
#' @param yi Vector of effect sizes
#' @param vi Vector of sampling variances
#' @param mods Model matrix or formula for moderators
#' @param data Optional data frame
#' @param method Heterogeneity estimator
#' @param B Number of bootstrap samples (default: 1000)
#' @param conf_level Confidence level (default: 0.95)
#' @param verbose Show progress
#'
#' @return List with confidence intervals and diagnostics
#' @export
#'
r2het_boot <- function(yi, vi, mods = NULL, data = NULL, method = "REML",
                       B = 1000, conf_level = 0.95, verbose = TRUE) {

  k <- length(yi)
  alpha <- 1 - conf_level

  # Storage
  r2het_boot <- rep(NA, B)
  r2het_cv_boot <- rep(NA, B)

  if(verbose) pb <- txtProgressBar(min = 0, max = B, style = 3)

  for(b in 1:B) {
    # Bootstrap sample
    idx <- sample(1:k, k, replace = TRUE)
    yi_boot <- yi[idx]
    vi_boot <- vi[idx]

    if(!is.null(mods)) {
      if(inherits(mods, "matrix")) {
        mods_boot <- mods[idx,, drop = FALSE]
      } else {
        if(!is.null(data)) {
          data_boot <- data[idx,]
        }
      }
    }

    # Calculate R²_het
    tryCatch({
      if(!is.null(data) & !inherits(mods, "matrix")) {
        result <- r2het_cv(yi_boot, vi_boot, mods, data_boot, method,
                           cv_method = "loo", verbose = FALSE)
      } else {
        result <- r2het_cv(yi_boot, vi_boot, mods_boot, NULL, method,
                           cv_method = "loo", verbose = FALSE)
      }

      r2het_boot[b] <- result$r2het_apparent
      r2het_cv_boot[b] <- result$r2het_corrected
    }, error = function(e) {})

    if(verbose) setTxtProgressBar(pb, b)
  }

  if(verbose) close(pb)

  # Remove NAs
  r2het_boot <- r2het_boot[!is.na(r2het_boot)]
  r2het_cv_boot <- r2het_cv_boot[!is.na(r2het_cv_boot)]

  # Calculate CIs
  if(length(r2het_boot) > B/2) {
    ci_apparent <- quantile(r2het_boot, c(alpha/2, 1-alpha/2))
    mean_apparent <- mean(r2het_boot)
    se_apparent <- sd(r2het_boot)
  } else {
    ci_apparent <- c(NA, NA)
    mean_apparent <- NA
    se_apparent <- NA
  }

  if(length(r2het_cv_boot) > B/2) {
    ci_corrected <- quantile(r2het_cv_boot, c(alpha/2, 1-alpha/2))
    mean_corrected <- mean(r2het_cv_boot)
    se_corrected <- sd(r2het_cv_boot)
    prop_at_zero <- mean(r2het_cv_boot < 0.01)
  } else {
    ci_corrected <- c(NA, NA)
    mean_corrected <- NA
    se_corrected <- NA
    prop_at_zero <- NA
  }

  return(list(
    ci_apparent = ci_apparent,
    ci_corrected = ci_corrected,
    mean_apparent = mean_apparent,
    mean_corrected = mean_corrected,
    se_apparent = se_apparent,
    se_corrected = se_corrected,
    prop_at_zero = prop_at_zero,
    convergence = length(r2het_boot)/B * 100,
    bootstrap_values = list(apparent = r2het_boot, corrected = r2het_cv_boot)
  ))
}

#' Check for Overfitting in Meta-Regression
#'
#' @param yi Vector of effect sizes
#' @param vi Vector of sampling variances
#' @param mods Model matrix or formula for moderators
#' @param data Optional data frame
#' @param method Heterogeneity estimator
#' @param B Number of bootstrap samples
#'
#' @return Comprehensive overfitting assessment
#' @export
#'
check_overfitting <- function(yi, vi, mods = NULL, data = NULL,
                              method = "REML", B = 500) {

  k <- length(yi)

  # Basic check
  if(is.null(mods)) {
    return(list(
      k = k,
      p = 1,
      k_per_p = k,
      risk_category = "None",
      recommendation = "No moderators - no overfitting risk"
    ))
  }

  # Get p
  if(inherits(mods, "matrix")) {
    p <- ncol(mods)
  } else if(inherits(mods, "formula")) {
    temp_fit <- metafor::rma(yi = yi, vi = vi, mods = mods,
                             data = data, method = method)
    p <- length(coef(temp_fit))
  }

  k_per_p <- k/p

  # Risk categories
  if(k < 20 | k_per_p < 5) {
    risk_category <- "Extreme"
    expected_optimism <- ">40%"
    recommendation <- "DO NOT conduct meta-regression - sample size too small"
  } else if(k_per_p < 10) {
    risk_category <- "Severe"
    expected_optimism <- "20-40%"
    recommendation <- "Results highly unreliable - consider exploratory only"
  } else if(k_per_p < 15) {
    risk_category <- "Moderate"
    expected_optimism <- "10-20%"
    recommendation <- "Interpret with caution - report optimism correction"
  } else {
    risk_category <- "Low"
    expected_optimism <- "<10%"
    recommendation <- "Acceptable sample size - still report optimism correction"
  }

  # Run full analysis
  cv_result <- r2het_cv(yi, vi, mods, data, method, verbose = FALSE)
  boot_result <- r2het_boot(yi, vi, mods, data, method, B = B, verbose = FALSE)

  # Create report
  report <- list(
    k = k,
    p = p,
    k_per_p = round(k_per_p, 1),
    risk_category = risk_category,
    expected_optimism = expected_optimism,
    actual_optimism = round(cv_result$optimism * 100, 1),
    r2het_apparent = round(cv_result$r2het_apparent * 100, 1),
    r2het_corrected = round(cv_result$r2het_corrected * 100, 1),
    ci_corrected = round(boot_result$ci_corrected * 100, 1),
    recommendation = recommendation,
    convergence_rate = cv_result$convergence_rate
  )

  class(report) <- c("metaoverfit", "list")
  return(report)
}

#' Sample Size Recommendation for Meta-Regression
#'
#' @param p Number of parameters (including intercept)
#' @param target_optimism Maximum acceptable optimism (default: 0.10)
#'
#' @return Minimum k recommendation
#' @export
#'
sample_size_recommendation <- function(p, target_optimism = 0.10) {

  # Based on empirical findings
  if(target_optimism <= 0.05) {
    min_ratio <- 20
  } else if(target_optimism <= 0.10) {
    min_ratio <- 15
  } else if(target_optimism <= 0.20) {
    min_ratio <- 10
  } else {
    min_ratio <- 5
  }

  min_k <- max(20, ceiling(p * min_ratio))

  cat("Sample Size Recommendation\n")
  cat(strrep("-", 40), "\n")
  cat("Parameters (p):", p, "\n")
  cat("Target optimism:", target_optimism * 100, "%\n")
  cat("Minimum k/p ratio:", min_ratio, "\n")
  cat("MINIMUM k required:", min_k, "\n")
  cat("\nNote: This ensures optimism <", target_optimism * 100, "%\n")

  return(invisible(min_k))
}

#' Print Method for metaoverfit Objects
#'
#' @param x metaoverfit object
#' @param ... Additional arguments
#'
#' @export
print.metaoverfit <- function(x, ...) {
  cat("\n", strrep("=", 60), "\n")
  cat("META-REGRESSION OVERFITTING ASSESSMENT\n")
  cat(strrep("=", 60), "\n\n")

  cat("Sample Size:\n")
  cat("  k =", x$k, "studies\n")
  cat("  p =", x$p, "parameters\n")
  cat("  k/p ratio =", x$k_per_p, "\n\n")

  cat("Risk Assessment:\n")
  cat("  Category:", x$risk_category, "\n")
  cat("  Expected optimism:", x$expected_optimism, "\n")
  cat("  Actual optimism:", x$actual_optimism, "%\n\n")

  cat("R² for Heterogeneity:\n")
  cat("  Apparent R²_het:", x$r2het_apparent, "%\n")
  cat("  Corrected R²_het:", x$r2het_corrected, "%\n")
  cat("  95% CI:", paste0("[", x$ci_corrected[1], "%, ",
                          x$ci_corrected[2], "%]"), "\n\n")

  cat("RECOMMENDATION:\n")
  cat("  ", x$recommendation, "\n")
  cat("\n", strrep("=", 60), "\n")
}

#' Plot Overfitting Diagnostics
#'
#' @param result Output from check_overfitting or r2het_cv
#' @param type "bar" for comparison or "scatter" for predictions
#'
#' @return ggplot object
#' @export
#'
plot_overfitting <- function(result, type = "bar") {

  if(!requireNamespace("ggplot2", quietly = TRUE)) {
    stop("ggplot2 package required for plotting")
  }

  if(type == "bar") {
    # Bar plot comparing apparent vs corrected
    df <- data.frame(
      Type = c("Apparent", "Corrected"),
      R2het = c(result$r2het_apparent * 100,
                result$r2het_corrected * 100)
    )

    p <- ggplot2::ggplot(df, ggplot2::aes(x = Type, y = R2het, fill = Type)) +
      ggplot2::geom_bar(stat = "identity", width = 0.6) +
      ggplot2::scale_fill_manual(values = c("Apparent" = "#E74C3C",
                                            "Corrected" = "#27AE60")) +
      ggplot2::labs(x = "", y = "R²_het (%)",
                    title = "Overfitting in Meta-Regression",
                    subtitle = paste("Optimism:",
                                     round((result$r2het_apparent -
                                              result$r2het_corrected) * 100, 1), "%")) +
      ggplot2::theme_minimal() +
      ggplot2::theme(legend.position = "none")

  } else if(type == "scatter" & !is.null(result$predictions)) {
    # Scatter plot of predictions
    df <- data.frame(
      Observed = result$yi,
      Predicted = result$predictions
    )

    p <- ggplot2::ggplot(df, ggplot2::aes(x = Predicted, y = Observed)) +
      ggplot2::geom_point(size = 3, alpha = 0.7) +
      ggplot2::geom_abline(slope = 1, intercept = 0,
                           linetype = "dashed", color = "red") +
      ggplot2::labs(x = "Predicted Effect Size", y = "Observed Effect Size",
                    title = "Cross-Validation Performance",
                    subtitle = paste("Correlation:",
                                     round(result$correlation, 3))) +
      ggplot2::theme_minimal()
  }

  return(p)
}
